            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"q1\": \"Floral\",\n  \"q2\": \"Moderate\",\n  \"q3\": \"Daily\",\n  \"q4\": \"Spring\",\n  \"q5\": \"Feminine\",\n  \"q6\": \"Citrus\",\n  \"q7\": \"Vanilla\",\n  \"q8\": \"Warm\",\n  \"q9\": \"Slightly sweet\",\n  \"q10\": \"Natural\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/quiz/recommend/ai",
          "host": ["{{base_url}}"],
          "path": ["api", "quiz", "recommend", "ai"]
        },
        "description": "Get AI-powered recommendations using Google Gemini"
      },
      "response": []
    },
