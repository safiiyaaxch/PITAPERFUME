    {
      "name": "1. Get Quiz Questions",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/quiz/questions",
          "host": ["{{base_url}}"],
          "path": ["api", "quiz", "questions"]
        },
        "description": "Fetch all quiz questions and options"
      },
      "response": []
    },
    {
